{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scourgify",
  "version": "0.0.0",
  "identifier": "com.hellager.scourgify",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scourgify",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/tray-light.ico",
      "icons/tray-dark.ico"
    ]
  }
}
