{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scourgify",
  "version": "0.6.0",
  "identifier": "com.hellager.scourgify",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scourgify",
        "width": 600,
        "height": 400,
        "minWidth": 400,
        "minHeight": 320,
        "visible": false,
        "dragDropEnabled": false,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/light/icon.ico",
      "icons/dark/icon.ico"
    ]
  }
}
